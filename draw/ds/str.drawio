<mxfile host="Electron" pages="2">
  <diagram name="kmp" id="YrWYIYi8XIOMsQa9y0m7">
    <mxGraphModel dx="2020" dy="1139" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1" value="KMP 算法：AAAAAB 找 AAAB 极详细推导过程" vertex="1">
          <mxGeometry height="50" width="800" x="420" y="30" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=15;fontStyle=1;fontSize=16;fontFamily=Courier New;" value="核心基石：Next 数组 (AAAB)&#xa;Index: 0  1  2  3&#xa;Char:  A  A  A  B&#xa;Next:  0  1  2  0" vertex="1">
          <mxGeometry height="120" width="300" x="70" y="110" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-3" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" value="阶段 1：一路顺风直到失配" vertex="1">
          <mxGeometry height="30" width="300" x="420" y="110" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-4" parent="1" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontFamily=Courier New;spacingLeft=10;" value="Text:      [A] [A] [A]  A   A   B&#xa;Pattern:   [A] [A] [A]  B&#xa;Pointer:    0   1   2   3 (j)" vertex="1">
          <mxGeometry height="90" width="450" x="420" y="140" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-5" parent="1" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;" value="i 从 0 走到 2，j 跟着走到 2。&#xa;前三位 &#39;AAA&#39; 完全匹配。&#xa;当前指针: i=3, j=3" vertex="1">
          <mxGeometry height="90" width="250" x="890" y="140" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-6" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" value="阶段 2：第一次失配与 j 回退" vertex="1">
          <mxGeometry height="30" width="300" x="420" y="260" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-7" parent="1" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontFamily=Courier New;spacingLeft=10;" value="Text:      A   A   A  [A]  A   B   (i=3)&#xa;Pattern:   A   A   A  [B]          (j=3)&#xa;Status:             Mismatch! (A != B)" vertex="1">
          <mxGeometry height="90" width="450" x="420" y="290" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-8" parent="1" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#FF0000" value="💡 关键动作：&#xa;1. 发现 Pattern[3] != Text[3]&#xa;2. 查 Next[3-1] = Next[2] = 2&#xa;3. j 回退到 2，i 保持 3 不变！" vertex="1">
          <mxGeometry height="90" width="300" x="890" y="290" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-9" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" value="阶段 3：在 i=3 处重新比较回退后的 j" vertex="1">
          <mxGeometry height="30" width="400" x="420" y="410" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-10" parent="1" style="text;html=1;strokeColor=#d79b00;fillColor=#ffe6cc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontFamily=Courier New;spacingLeft=10;" value="Text:      A   A   A  [A]  A   B   (i=3)&#xa;Pattern:       A   A  [A]  B          (j=2)&#xa;Status:             Match! (A == A)" vertex="1">
          <mxGeometry height="90" width="450" x="420" y="440" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-11" parent="1" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;" value="由于 j 回退到了 2，&#xa;现在比较 Text[3] 和 Pattern[2]。&#xa;匹配成功！i 和 j 同时 ++。" vertex="1">
          <mxGeometry height="90" width="250" x="890" y="440" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-12" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" value="阶段 4：再次遇到 B 的挑战 (i=4)" vertex="1">
          <mxGeometry height="30" width="400" x="420" y="560" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-13" parent="1" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontFamily=Courier New;spacingLeft=10;" value="Text:      A   A   A   A  [A]  B   (i=4)&#xa;Pattern:       A   A   A  [B]          (j=3)&#xa;Status:             Mismatch! (A != B)" vertex="1">
          <mxGeometry height="90" width="450" x="420" y="590" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-14" parent="1" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;" value="又到了失配点！&#xa;j 再次从 3 回退到 Next[2] = 2。&#xa;i 停在 4 不准动。" vertex="1">
          <mxGeometry height="90" width="250" x="890" y="590" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-15" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" value="阶段 5：最后的冲刺 (匹配成功)" vertex="1">
          <mxGeometry height="30" width="400" x="420" y="710" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-16" parent="1" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontFamily=Courier New;spacingLeft=10;" value="Text:      A   A   A   A   A   B   (i=5)&#xa;Pattern:               A   A   A   B   (j=3)&#xa;Status:                     MATCHED!" vertex="1">
          <mxGeometry height="90" width="450" x="420" y="740" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-17" parent="1" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;" value="1. i=4 与 j=2 匹配成功。&#xa;2. i=5 与 j=3 匹配成功！&#xa;至此，找到完整模式串。" vertex="1">
          <mxGeometry height="90" width="250" x="890" y="740" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-18" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=20;fontSize=16;fontStyle=1" value="🧠 KMP 核心逻辑总结：&#xa;1. 只要匹配成功：i++, j++ (勇往直前)&#xa;2. 一旦匹配失败：&#xa;   - 如果 j &gt; 0：i 不动，j = Next[j-1] (寻求跳板)&#xa;   - 如果 j = 0：i++ (彻底没戏，主串往后挪一步)" vertex="1">
          <mxGeometry height="120" width="1070" x="70" y="860" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-19" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;align=left;spacingLeft=10;verticalAlign=top;" value="Next 数组详细计算推导 (AAAB)" vertex="1">
          <mxGeometry height="370" width="300" x="70" y="280" as="geometry" />
        </mxCell>
        <mxCell id="Z9tqhHucUf5nhfq0Fkhp-20" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontFamily=Courier New;spacingLeft=5;" value="1. 子串 &#39;A&#39;&#xa;   前缀: -&#xa;   后缀: -&#xa;   LPS = 0&#xa;&#xa;2. 子串 &#39;AA&#39;&#xa;   前缀: {A}&#xa;   后缀: {A}&#xa;   LPS = 1 (&#39;A&#39;)&#xa;&#xa;3. 子串 &#39;AAA&#39;&#xa;   前缀: {A, AA}&#xa;   后缀: {AA, A}&#xa;   LPS = 2 (&#39;AA&#39;)&#xa;&#xa;4. 子串 &#39;AAAB&#39;&#xa;   前缀: {A, AA, AAA}&#xa;   后缀: {AAB, AB, B}&#xa;   LPS = 0" vertex="1">
          <mxGeometry height="330" width="280" x="80" y="310" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="Y-kCesIAGZGM5gXsvR5z" name="two-way">
    <mxGraphModel dx="1414" dy="797" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
